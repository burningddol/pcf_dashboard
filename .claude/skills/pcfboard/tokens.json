      "mono":    { "value": "12px", "family": "mono" }
    },
    "feature-settings": "'tnum', 'ss01', 'cv11'"
  },
  "spacing": {
    "1": { "value": "4px"  },
    "2": { "value": "8px"  },
    "3": { "value": "12px" },
    "4": { "value": "16px" },
    "5": { "value": "20px" },
    "6": { "value": "24px" },
    "7": { "value": "32px" },
    "8": { "value": "40px" },
    "9": { "value": "56px" }
  },
  "radius": {
    "1": { "value": "4px"  },
    "2": { "value": "6px",  "use": "Buttons, inputs, pills" },
    "3": { "value": "8px",  "use": "Cards" },
    "4": { "value": "10px" },
    "5": { "value": "14px" }
  },
  "shadow": {
    "1":   { "value": "0 1px 0 rgba(15,30,45,0.04)", "use": "Subtle separator" },
    "2":   { "value": "0 1px 2px rgba(15,30,45,0.06), 0 1px 0 rgba(15,30,45,0.04)", "use": "Default card" },
    "3":   { "value": "0 4px 12px rgba(15,30,45,0.08), 0 1px 2px rgba(15,30,45,0.06)", "use": "Hover, sidepanel" },
    "pop": { "value": "0 12px 32px rgba(15,30,45,0.12), 0 2px 6px rgba(15,30,45,0.08)", "use": "Popovers, modals" },
    "focus-ring": { "value": "0 0 0 3px rgba(15,76,92,0.15)" }
  },
  "duration": {
    "fast":  { "value": "120ms" },
    "base":  { "value": "180ms" },
    "slow":  { "value": "320ms" }
  },
  "control": {
    "height-sm":  { "value": "26px" },
    "height":     { "value": "30px" },
    "height-lg":  { "value": "34px" }
  },
  "chart": {
    "axis-stroke":      { "value": "#D9DEE3" },
    "gridline":         { "value": "#EEF0F3", "use": "Dashed 2 3" },
    "bar-gap":          { "value": "8px" },
    "bar-max-width":    { "value": "38px" },
    "sankey-node-gap":  { "value": "6px" },
    "sankey-link-opacity": { "value": "0.55" }
  }
}
