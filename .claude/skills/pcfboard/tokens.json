{
  "$meta": {
    "name": "PCFBoard Design Tokens",
    "version": "1.0.0",
    "description": "Carbon accounting SaaS — Stripe/Mixpanel-density analytics tone."
  },
  "color": {
    "surface": {
      "bg":     { "value": "#FFFFFF" },
      "bg-1":   { "value": "#FAFBFC" },
      "bg-2":   { "value": "#F4F6F8" },
      "bg-3":   { "value": "#EEF1F4" },
      "bg-inset": { "value": "#F7F9FA" }
    },
    "border": {
      "line":         { "value": "#E6E9ED" },
      "line-2":       { "value": "#D9DEE3" },
      "line-strong":  { "value": "#C2C8CF" },
      "line-soft":    { "value": "#EEF0F3" }
    },
    "fg": {
      "fg":   { "value": "#0D1116", "use": "Primary text (numbers, headings)" },
      "fg-1": { "value": "#1F2630", "use": "Strong body text" },
      "fg-2": { "value": "#4A5560", "use": "Body text" },
      "fg-3": { "value": "#6B7682", "use": "Secondary, captions" },
      "fg-4": { "value": "#94A0AD", "use": "Tertiary, axis labels" }
    },
    "accent": {
      "accent":       { "value": "#0F4C5C", "use": "Primary action only — used sparingly" },
      "accent-hover": { "value": "#0C3E4B" },
      "accent-soft":  { "value": "#E7F1F3" },
      "accent-fg":    { "value": "#FFFFFF" }
    },
    "scope": {
      "1":      { "value": "#0F4C5C", "use": "Scope 1 — direct emissions" },
      "1-soft": { "value": "#D6E4E8" },
      "2":      { "value": "#2A9D8F", "use": "Scope 2 — purchased electricity/steam" },
      "2-soft": { "value": "#D8EEEB" },
      "3":      { "value": "#A7C957", "use": "Scope 3 — value chain" },
      "3-soft": { "value": "#ECF2D6" }
    },
    "lifecycle": {
      "raw":  { "value": "#0F4C5C", "use": "Raw material" },
      "mfg":  { "value": "#2A9D8F", "use": "Manufacturing" },
      "dist": { "value": "#4A90A4", "use": "Distribution" },
      "use":  { "value": "#8AAAB1", "use": "Use phase" },
      "eol":  { "value": "#C2CFB6", "use": "End of life" }
    },
    "status": {
      "pos":      { "value": "#0A7C4A", "use": "Emissions DOWN = good (inverted from finance)" },
      "pos-soft": { "value": "#E3F3EB" },
      "neg":      { "value": "#B42318", "use": "Emissions UP = bad" },
      "neg-soft": { "value": "#FDECEB" },
      "warn":      { "value": "#B25E09" },
      "warn-soft": { "value": "#FBF0E0" },
      "info":      { "value": "#1E5FB4" },
      "info-soft": { "value": "#E6EEF9" }
    }
  },
  "type": {
    "family": {
      "sans": { "value": "Pretendard, 'IBM Plex Sans KR', 'IBM Plex Sans', -apple-system, BlinkMacSystemFont, system-ui, sans-serif" },
      "mono": { "value": "'IBM Plex Mono', 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, monospace" },
      "num":  { "value": "'IBM Plex Mono', ui-monospace, monospace", "use": "All numerals — tabular" }
    },
    "size": {
