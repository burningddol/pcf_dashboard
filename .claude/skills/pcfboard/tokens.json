      "h2":      { "value": "17px", "weight": 600 },
      "h3":      { "value": "14px", "weight": 600 },
      "body":    { "value": "13px", "weight": 400 },
      "sm":      { "value": "12px", "weight": 400 },
      "xs":      { "value": "11px", "weight": 400 },
